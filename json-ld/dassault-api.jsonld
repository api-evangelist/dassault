  "potentialAction": [
    {
      "@type": "Action",
      "name": "searchOrders",
      "description": "Search Orders using various filters",
      "httpMethod": "POST",
      "urlTemplate": "/order/api4partners/v0/orders/search",
      "tags": [
        "orders"
      ]
    },
    {
      "@type": "Action",
      "name": "getOrderDetails",
      "description": "Get Order details",
      "httpMethod": "GET",
      "urlTemplate": "/order/api4partners/v0/orders/{id}",
      "tags": [
        "orders"
      ]
    },
    {
      "@type": "Action",
      "name": "searchPriceList",
      "description": "Retrieve Price Lists",
      "httpMethod": "GET",
      "urlTemplate": "/order/api4partners/v0/price-lists/search",
      "tags": [
        "price-lists"
      ]
    },
    {
      "@type": "Action",
      "name": "searchAccreditations",
      "description": "Retrieve Accreditations",
      "httpMethod": "GET",
      "urlTemplate": "/order/api4partners/v0/accreditations/search",
      "tags": [
        "accreditations"
      ]
    },
    {
      "@type": "Action",
      "name": "generateApiKey",
      "description": "Generate a new API key",
      "httpMethod": "POST",
      "urlTemplate": "/order/api4partners/v0/apikeys",
      "tags": [
        "apikeys"
      ]
    },
    {
      "@type": "Action",
      "name": "createLeadsOpportunities",
