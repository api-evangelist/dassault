        "leads-opportunities"
      ]
    },
    {
      "@type": "Action",
      "name": "updateLeadOpportunitiesDetails",
      "description": "Update a lead-opportunity object",
      "httpMethod": "PATCH",
      "urlTemplate": "/sales/api4partners/v0/leads-opportunities/{id}",
      "tags": [
        "leads-opportunities"
      ]
    },
    {
      "@type": "Action",
      "name": "getLeadsOpportunities",
      "description": "Get details of a lead-opportunity object",
      "httpMethod": "GET",
      "urlTemplate": "/sales/api4partners/v0/leads-opportunities/{id}",
      "tags": [
        "leads-opportunities"
      ]
    },
    {
      "@type": "Action",
      "name": "searchLeadsOpportunities",
